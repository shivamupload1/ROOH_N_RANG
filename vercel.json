{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/main",
      "destination": "/main.html"
    },
    {
      "source": "/client-gallery",
      "destination": "/client-gallery.html"
    },
    {
      "source": "/featured-stories",
      "destination": "/featured-stories.html"
    },
    {
      "source": "/stories/bharat-mehak",
      "destination": "/featured-story-bharat-mehak.html"
    },
    {
      "source": "/stories/meera-arjun",
      "destination": "/featured-story-meera-arjun.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
